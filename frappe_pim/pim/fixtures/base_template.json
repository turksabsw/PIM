    "quality_rules": [
        {
            "rule_code": "req_short_description",
            "rule_name": "Short Description Required",
            "rule_type": "required_field",
            "target_attribute": "short_description",
            "severity": "error",
            "weight": 10,
            "message": "Product must have a short description",
            "description": "Every product must have a short description for catalog display"
        },
        {
            "rule_code": "req_weight",
            "rule_name": "Weight Required",
            "rule_type": "required_field",
            "target_attribute": "weight",
            "severity": "warning",
            "weight": 5,
            "message": "Product should have a weight specified",
            "description": "Weight is required for shipping calculations and logistics"
        },
        {
            "rule_code": "req_dimensions",
            "rule_name": "Dimensions Recommended",
            "rule_type": "attribute_group_completeness",
            "target_group": "dimensions",
            "min_filled_percentage": 50,
            "severity": "warning",
            "weight": 3,
            "message": "Product should have at least height, width, and depth specified",
            "description": "Physical dimensions needed for packaging and shipping calculations"
        },
        {
            "rule_code": "req_media",
            "rule_name": "Product Image Required",
            "rule_type": "media_presence",
            "min_images": 1,
            "severity": "error",
            "weight": 10,
            "message": "Product must have at least one image",
            "description": "At least one product image is essential for catalog display"
        },
        {
            "rule_code": "req_seo_title",
            "rule_name": "SEO Title Recommended",
            "rule_type": "required_field",
            "target_attribute": "meta_title",
            "severity": "info",
            "weight": 2,
            "message": "Product should have a SEO meta title for search engine visibility",
            "description": "Meta title improves search engine ranking and click-through rates"
        },
        {
            "rule_code": "req_seo_description",
            "rule_name": "SEO Description Recommended",
            "rule_type": "required_field",
            "target_attribute": "meta_description",
            "severity": "info",
            "weight": 2,
            "message": "Product should have a SEO meta description",
            "description": "Meta description shown in search engine results improves CTR"
        },
        {
            "rule_code": "val_short_description_length",
            "rule_name": "Short Description Length",
            "rule_type": "value_constraint",
            "target_attribute": "short_description",
            "min_length": 20,
            "max_length": 500,
            "severity": "warning",
            "weight": 3,
            "message": "Short description should be between 20 and 500 characters",
            "description": "Descriptions that are too short or too long hurt product listings"
        },
        {
            "rule_code": "val_meta_title_length",
            "rule_name": "Meta Title Length",
            "rule_type": "value_constraint",
            "target_attribute": "meta_title",
            "min_length": 10,
            "max_length": 70,
            "severity": "info",
            "weight": 1,
            "message": "Meta title should be between 10 and 70 characters for optimal SEO",
            "description": "Search engines truncate titles longer than 60-70 characters"
        },
        {
            "rule_code": "val_meta_description_length",
            "rule_name": "Meta Description Length",
            "rule_type": "value_constraint",
            "target_attribute": "meta_description",
            "min_length": 50,
            "max_length": 160,
            "severity": "info",
            "weight": 1,
            "message": "Meta description should be between 50 and 160 characters for optimal SEO",
            "description": "Search engines truncate descriptions longer than 155-160 characters"
        },
        {
            "rule_code": "val_weight_positive",
            "rule_name": "Weight Must Be Positive",
            "rule_type": "value_constraint",
            "target_attribute": "weight",
            "min_value": 0.001,
            "severity": "error",
            "weight": 5,
            "message": "Weight must be a positive number greater than zero",
            "description": "Zero or negative weight values indicate data entry errors"
        },
        {
            "rule_code": "req_brand_or_manufacturer",
            "rule_name": "Brand or Manufacturer Required",
            "rule_type": "any_of_required",
            "target_attributes": ["brand", "manufacturer"],
            "severity": "warning",
            "weight": 3,
            "message": "Product should have either a brand or manufacturer specified",
            "description": "Brand and manufacturer identification is important for product trust"
        },
        {
            "rule_code": "req_country_for_compliance",
            "rule_name": "Country of Origin for Compliance",
            "rule_type": "required_field",
            "target_attribute": "country_of_origin",
            "severity": "info",
            "weight": 2,
            "message": "Country of origin should be specified for trade compliance",
            "description": "Required for customs declarations and trade compliance in most jurisdictions"
        }
    ]
