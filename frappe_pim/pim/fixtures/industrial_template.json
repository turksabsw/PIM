    "quality_rules": [
        {
            "rule_code": "ind_req_material_grade",
            "rule_name": "Material Grade Required",
            "rule_type": "required_field",
            "target_attribute": "material_grade",
            "severity": "error",
            "weight": 10,
            "message": "Industrial products must specify a material grade designation",
            "description": "Material grade is essential for procurement, quality control, and regulatory compliance"
        },
        {
            "rule_code": "ind_req_material_type",
            "rule_name": "Material Type Required",
            "rule_type": "required_field",
            "target_attribute": "material_type",
            "severity": "error",
            "weight": 8,
            "message": "Industrial products must specify the material type",
            "description": "Material type classification is required for inventory management and sourcing"
        },
        {
            "rule_code": "ind_req_tolerance",
            "rule_name": "Tolerance Recommended for Machined Parts",
            "rule_type": "required_field",
            "target_attribute": "tolerance",
            "severity": "warning",
            "weight": 6,
            "message": "Machined parts should specify dimensional tolerances",
            "description": "Tolerance specifications are critical for parts interchangeability and quality inspection"
        },
        {
            "rule_code": "ind_req_certification",
            "rule_name": "Certification Recommended",
            "rule_type": "required_field",
            "target_attribute": "ind_certification",
            "severity": "warning",
            "weight": 5,
            "message": "Products should list applicable certifications for quality assurance",
            "description": "Industry certifications build customer trust and are often required for regulated applications"
        },
        {
            "rule_code": "ind_req_surface_finish",
            "rule_name": "Surface Finish Recommended",
            "rule_type": "required_field",
            "target_attribute": "surface_finish",
            "severity": "info",
            "weight": 3,
            "message": "Specifying surface finish improves product clarity for customers",
            "description": "Surface finish affects corrosion resistance, friction, and aesthetic appearance"
        },
        {
            "rule_code": "ind_req_drawing",
            "rule_name": "Drawing Number Recommended",
            "rule_type": "required_field",
            "target_attribute": "drawing_number",
            "severity": "info",
            "weight": 3,
            "message": "Linking an engineering drawing number aids traceability and reordering",
            "description": "Drawing references enable precise reordering and quality verification"
        },
        {
            "rule_code": "ind_req_traceability",
            "rule_name": "Traceability Code for Raw Materials",
            "rule_type": "required_field",
            "target_attribute": "traceability_code",
            "severity": "warning",
            "weight": 5,
            "message": "Raw materials should have a heat or lot number for traceability",
            "description": "Material traceability is required by many industry standards (AS9100, IATF 16949, etc.)"
        },
        {
            "rule_code": "ind_tensile_positive",
            "rule_name": "Tensile Strength Must Be Positive",
            "rule_type": "value_constraint",
            "target_attribute": "tensile_strength",
            "min_value": 0.1,
            "severity": "error",
            "weight": 5,
            "message": "Tensile strength must be a positive number",
            "description": "Zero or negative tensile strength values indicate data entry errors"
        },
        {
            "rule_code": "ind_min_images",
            "rule_name": "Industrial Minimum Images",
            "rule_type": "media_presence",
            "min_images": 1,
            "severity": "warning",
            "weight": 4,
            "message": "Industrial products should have at least one product photo or technical drawing",
            "description": "Visual documentation aids product identification and reduces ordering errors"
        }
    ],

