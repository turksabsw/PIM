    "quality_rules": [
        {
            "rule_code": "fashion_req_color",
            "rule_name": "Color Required for Fashion",
            "rule_type": "required_field",
            "target_attribute": "color",
            "severity": "error",
            "weight": 10,
            "message": "Fashion products must specify a color",
            "description": "Color is essential for fashion product identification and variant creation"
        },
        {
            "rule_code": "fashion_req_gender",
            "rule_name": "Gender Required",
            "rule_type": "required_field",
            "target_attribute": "gender",
            "severity": "error",
            "weight": 8,
            "message": "Fashion products must specify a target gender",
            "description": "Gender classification is required for proper merchandising and navigation"
        },
        {
            "rule_code": "fashion_req_composition",
            "rule_name": "Fabric Composition Required",
            "rule_type": "required_field",
            "target_attribute": "fabric_composition",
            "severity": "error",
            "weight": 8,
            "message": "Fabric composition must be specified for regulatory compliance",
            "description": "EU and US textile regulations require fabric composition disclosure on product labels"
        },
        {
            "rule_code": "fashion_req_care",
            "rule_name": "Care Instructions Recommended",
            "rule_type": "required_field",
            "target_attribute": "care_instructions",
            "severity": "warning",
            "weight": 5,
            "message": "Products should include care and washing instructions",
            "description": "Care instructions help customers maintain the product and reduce returns"
        },
        {
            "rule_code": "fashion_req_season",
            "rule_name": "Season Recommended",
            "rule_type": "required_field",
            "target_attribute": "season",
            "severity": "info",
            "weight": 3,
            "message": "Assigning a season helps with collection management and markdown planning",
            "description": "Season classification enables seasonal merchandising and inventory planning"
        },
        {
            "rule_code": "fashion_req_fit",
            "rule_name": "Fit Recommended for Apparel",
            "rule_type": "required_field",
            "target_attribute": "fit",
            "severity": "warning",
            "weight": 4,
            "message": "Specifying fit type helps customers choose the right size",
            "description": "Fit information reduces size-related returns and improves customer satisfaction"
        },
        {
            "rule_code": "fashion_min_images",
            "rule_name": "Fashion Minimum Images",
            "rule_type": "media_presence",
            "min_images": 3,
            "severity": "warning",
            "weight": 7,
            "message": "Fashion products should have at least 3 images (front, back, detail)",
            "description": "Multiple product images significantly reduce return rates in fashion e-commerce"
        },
        {
            "rule_code": "fashion_composition_format",
            "rule_name": "Fabric Composition Format",
            "rule_type": "value_constraint",
            "target_attribute": "fabric_composition",
            "min_length": 5,
            "max_length": 500,
            "severity": "warning",
            "weight": 3,
            "message": "Fabric composition should include percentages (e.g., 95% Cotton, 5% Elastane)",
            "description": "Standardized composition format ensures regulatory compliance and customer clarity"
        }
    ],

