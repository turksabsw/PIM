{
  "doctype": "DocType",
  "name": "Product Social Link",
  "module": "PIM",
  "istable": 1,
  "editable_grid": 1,
  "fields": [
    {
      "fieldname": "platform",
      "fieldtype": "Select",
      "label": "Platform",
      "options": "Facebook\nInstagram\nTwitter/X\nYouTube\nLinkedIn\nTikTok\nPinterest\nWhatsApp\nTelegram\nWebsite\nOther",
      "default": "Website",
      "reqd": 1,
      "in_list_view": 1,
      "columns": 2
    },
    {
      "fieldname": "url",
      "fieldtype": "Data",
      "label": "URL",
      "options": "URL",
      "reqd": 1,
      "in_list_view": 1,
      "columns": 4
    },
    {
      "fieldname": "title",
      "fieldtype": "Data",
      "label": "Title",
      "description": "Display title for the link",
      "in_list_view": 1,
      "columns": 2
    },
    {
      "fieldname": "sort_order",
      "fieldtype": "Int",
      "label": "Sort Order",
      "default": 0,
      "in_list_view": 1,
      "columns": 1
    },
    {
      "fieldname": "is_active",
      "fieldtype": "Check",
      "label": "Is Active",
      "default": 1,
      "in_list_view": 1,
      "columns": 1
    },
    {
      "fieldname": "notes",
      "fieldtype": "Small Text",
      "label": "Notes",
      "description": "Additional notes about this social link"
    }
  ],
  "field_order": [
    "platform",
    "url",
    "title",
    "sort_order",
    "is_active",
    "notes"
  ]
}