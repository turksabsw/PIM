{
  "doctype": "DocType",
  "name": "Product Barcode Item",
  "module": "PIM",
  "istable": 1,
  "editable_grid": 1,
  "fields": [
    {
      "fieldname": "barcode_type",
      "fieldtype": "Select",
      "label": "Barcode Type",
      "options": "EAN-13\nUPC-A\nEAN-8\nUPC-E\nCode 128\nCode 39\nQR Code\nISBN\nISSN\nGTIN-14\nOther",
      "default": "EAN-13",
      "reqd": 1,
      "in_list_view": 1,
      "columns": 2
    },
    {
      "fieldname": "barcode",
      "fieldtype": "Data",
      "label": "Barcode",
      "reqd": 1,
      "in_list_view": 1,
      "columns": 3
    },
    {
      "fieldname": "is_primary",
      "fieldtype": "Check",
      "label": "Is Primary",
      "default": 0,
      "in_list_view": 1,
      "columns": 1,
      "description": "Mark as primary barcode for this product/variant"
    },
    {
      "fieldname": "apply_to_variant",
      "fieldtype": "Link",
      "label": "Apply to Variant Only",
      "options": "Product Variant",
      "description": "Leave empty to apply to all variants"
    },
    {
      "fieldname": "apply_to_uom",
      "fieldtype": "Link",
      "label": "Apply to UOM",
      "options": "UOM",
      "description": "Unit of measure this barcode applies to (e.g., Box, Carton, Pallet)"
    },
    {
      "fieldname": "valid_from",
      "fieldtype": "Date",
      "label": "Valid From"
    },
    {
      "fieldname": "valid_to",
      "fieldtype": "Date",
      "label": "Valid To"
    },
    {
      "fieldname": "notes",
      "fieldtype": "Small Text",
      "label": "Notes",
      "description": "Additional notes about this barcode"
    }
  ],
  "field_order": [
    "barcode_type",
    "barcode",
    "is_primary",
    "apply_to_variant",
    "apply_to_uom",
    "valid_from",
    "valid_to",
    "notes"
  ]
}