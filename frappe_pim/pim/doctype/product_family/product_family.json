{
  "doctype": "DocType",
  "name": "Product Family",
  "module": "PIM",
  "naming_rule": "By fieldname",
  "autoname": "field:family_code",
  "is_tree": 1,
  "nsm_parent_field": "parent_family",
  "allow_rename": 1,
  "track_changes": 1,
  "sort_field": "modified",
  "sort_order": "DESC",
  
  "fields": [
    {
      "fieldname": "family_name",
      "fieldtype": "Data",
      "label": "Family Name",
      "reqd": 1,
      "in_list_view": 1,
      "in_standard_filter": 1,
      "translatable": 1
    },
    {
      "fieldname": "family_code",
      "fieldtype": "Data",
      "label": "Family Code",
      "reqd": 1,
      "unique": 1,
      "in_list_view": 1,
      "description": "Unique identifier. Example: apparel, electronics"
    },
    {
      "fieldname": "column_break_1",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "parent_family",
      "fieldtype": "Link",
      "label": "Parent Family",
      "options": "Product Family",
      "in_standard_filter": 1
    },
    {
      "fieldname": "naming_series_prefix",
      "fieldtype": "Data",
      "label": "SKU Prefix",
      "description": "Prefix for auto-generated SKUs. Example: TSH-, ELK-"
    },
    {
      "fieldname": "section_break_tree",
      "fieldtype": "Section Break",
      "label": "Tree Structure",
      "collapsible": 1
    },
    {
      "fieldname": "lft",
      "fieldtype": "Int",
      "hidden": 1,
      "label": "Left",
      "no_copy": 1,
      "read_only": 1
    },
    {
      "fieldname": "rgt",
      "fieldtype": "Int",
      "hidden": 1,
      "label": "Right",
      "no_copy": 1,
      "read_only": 1
    },
    {
      "fieldname": "is_group",
      "fieldtype": "Check",
      "label": "Is Group",
      "default": 0
    },
    {
      "fieldname": "old_parent",
      "fieldtype": "Link",
      "label": "Old Parent",
      "options": "Product Family"
    },
    {
      "fieldname": "section_break_settings",
      "fieldtype": "Section Break",
      "label": "Settings"
    },
    {
      "fieldname": "is_active",
      "fieldtype": "Check",
      "label": "Is Active",
      "default": 1
    },
    {
      "fieldname": "allow_variants",
      "fieldtype": "Check",
      "label": "Allow Variants",
      "description": "Products in this family can have variants (SKUs)",
      "default": 1
    },
    {
      "fieldname": "column_break_settings",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "inherit_parent_attributes",
      "fieldtype": "Check",
      "label": "Inherit Parent Attributes",
      "description": "Automatically include attributes from parent family",
      "default": 1
    },
    {
      "fieldname": "erp_item_group",
      "fieldtype": "Link",
      "label": "ERP Item Group",
      "options": "Item Group",
      "description": "Map to ERPNext Item Group for synced products"
    },
    {
      "fieldname": "section_break_attributes",
      "fieldtype": "Section Break",
      "label": "Attribute Template"
    },
    {
      "fieldname": "attributes",
      "fieldtype": "Table",
      "label": "Attributes",
      "options": "Family Attribute Template",
      "description": "Attributes that products in this family should have"
    },
    {
      "fieldname": "section_break_variant",
      "fieldtype": "Section Break",
      "label": "Variant Configuration",
      "depends_on": "eval:doc.allow_variants"
    },
    {
      "fieldname": "variant_attributes",
      "fieldtype": "Table MultiSelect",
      "label": "Variant Defining Attributes",
      "options": "Family Variant Attribute",
      "description": "Attributes that define product variants (e.g., Size, Color)"
    },
    {
      "fieldname": "section_break_media",
      "fieldtype": "Section Break",
      "label": "Media Configuration"
    },
    {
      "fieldname": "required_media_types",
      "fieldtype": "Small Text",
      "label": "Required Media Types",
      "description": "Comma-separated. Example: Main Image, Gallery, Video"
    },
    {
      "fieldname": "min_images",
      "fieldtype": "Int",
      "label": "Minimum Images Required",
      "default": 1
    },
    {
      "fieldname": "section_break_completeness",
      "fieldtype": "Section Break",
      "label": "Completeness Rules",
      "collapsible": 1
    },
    {
      "fieldname": "completeness_threshold",
      "fieldtype": "Percent",
      "label": "Completeness Threshold",
      "description": "Minimum score to be considered 'complete'",
      "default": 80
    },
    {
      "fieldname": "section_break_description",
      "fieldtype": "Section Break",
      "label": "Description",
      "collapsible": 1
    },
    {
      "fieldname": "description",
      "fieldtype": "Text Editor",
      "label": "Description"
    }
  ],
  
  "permissions": [
    {
      "role": "System Manager",
      "read": 1, "write": 1, "create": 1, "delete": 1, "export": 1, "import": 1
    },
    {
      "role": "PIM Manager",
      "read": 1, "write": 1, "create": 1, "delete": 1, "export": 1, "import": 1
    },
    {
      "role": "PIM User",
      "read": 1
    }
  ]
}
