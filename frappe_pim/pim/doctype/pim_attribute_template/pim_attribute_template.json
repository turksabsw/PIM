{
  "doctype": "DocType",
  "name": "PIM Attribute Template",
  "module": "PIM",
  "naming_rule": "By fieldname",
  "autoname": "field:template_code",
  "allow_rename": 1,
  "track_changes": 1,
  "sort_field": "modified",
  "sort_order": "DESC",

  "fields": [
    {
      "fieldname": "template_name",
      "fieldtype": "Data",
      "label": "Template Name",
      "reqd": 1,
      "in_list_view": 1,
      "in_standard_filter": 1,
      "translatable": 1,
      "description": "Display name for the attribute template"
    },
    {
      "fieldname": "template_code",
      "fieldtype": "Data",
      "label": "Template Code",
      "reqd": 1,
      "unique": 1,
      "in_list_view": 1,
      "description": "Unique identifier. Example: electronics_basic, apparel_size_color"
    },
    {
      "fieldname": "column_break_1",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "product_type",
      "fieldtype": "Link",
      "label": "Product Type",
      "options": "PIM Product Type",
      "in_standard_filter": 1,
      "description": "Optional: Link to a specific product type this template is designed for"
    },
    {
      "fieldname": "is_active",
      "fieldtype": "Check",
      "label": "Is Active",
      "default": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "section_break_description",
      "fieldtype": "Section Break",
      "label": "Description"
    },
    {
      "fieldname": "description",
      "fieldtype": "Text Editor",
      "label": "Description",
      "description": "Description of when and how to use this template"
    },
    {
      "fieldname": "section_break_attributes",
      "fieldtype": "Section Break",
      "label": "Attributes"
    },
    {
      "fieldname": "attributes",
      "fieldtype": "Table",
      "label": "Attributes",
      "options": "PIM Template Attribute",
      "reqd": 1,
      "description": "List of attributes included in this template"
    },
    {
      "fieldname": "section_break_metadata",
      "fieldtype": "Section Break",
      "label": "Metadata",
      "collapsible": 1
    },
    {
      "fieldname": "usage_count",
      "fieldtype": "Int",
      "label": "Usage Count",
      "read_only": 1,
      "default": 0,
      "description": "Number of product families or products using this template"
    },
    {
      "fieldname": "column_break_metadata",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "last_applied",
      "fieldtype": "Datetime",
      "label": "Last Applied",
      "read_only": 1,
      "description": "When this template was last applied to a product"
    }
  ],

  "permissions": [
    {
      "role": "System Manager",
      "read": 1, "write": 1, "create": 1, "delete": 1, "export": 1, "import": 1
    },
    {
      "role": "PIM Manager",
      "read": 1, "write": 1, "create": 1, "delete": 1, "export": 1, "import": 1
    },
    {
      "role": "PIM User",
      "read": 1
    }
  ]
}
