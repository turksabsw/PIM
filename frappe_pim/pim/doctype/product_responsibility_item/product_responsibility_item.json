{
  "doctype": "DocType",
  "name": "Product Responsibility Item",
  "module": "PIM",
  "istable": 1,
  "editable_grid": 1,
  "fields": [
    {
      "fieldname": "responsibility_role",
      "fieldtype": "Select",
      "label": "Responsibility Role",
      "options": "Sales Manager\nPurchasing Manager\nProduct Manager\nMarketing Manager\nQuality Manager\nContent Manager\nCategory Manager\nOther",
      "default": "Product Manager",
      "reqd": 1,
      "in_list_view": 1,
      "columns": 2
    },
    {
      "fieldname": "user",
      "fieldtype": "Link",
      "label": "Assigned User",
      "options": "User",
      "reqd": 1,
      "in_list_view": 1,
      "columns": 3
    },
    {
      "fieldname": "is_primary",
      "fieldtype": "Check",
      "label": "Is Primary",
      "default": 0,
      "in_list_view": 1,
      "columns": 1,
      "description": "Mark as primary responsible person for this role"
    },
    {
      "fieldname": "assigned_date",
      "fieldtype": "Date",
      "label": "Assigned Date",
      "default": "Today",
      "in_list_view": 1,
      "columns": 2
    },
    {
      "fieldname": "notes",
      "fieldtype": "Small Text",
      "label": "Notes",
      "description": "Additional notes about the responsibility assignment"
    }
  ],
  "field_order": [
    "responsibility_role",
    "user",
    "is_primary",
    "assigned_date",
    "notes"
  ]
}