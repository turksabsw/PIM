{
  "doctype": "DocType",
  "name": "PIM Attribute Group",
  "module": "PIM",
  "naming_rule": "By fieldname",
  "autoname": "field:group_code",
  "is_submittable": 0,
  "allow_rename": 1,
  "track_changes": 1,
  "sort_field": "sort_order",
  "sort_order": "ASC",

  "fields": [
    {
      "fieldname": "group_name",
      "fieldtype": "Data",
      "label": "Group Name",
      "reqd": 1,
      "in_list_view": 1,
      "in_standard_filter": 1,
      "translatable": 1,
      "description": "Display name for the attribute group"
    },
    {
      "fieldname": "group_code",
      "fieldtype": "Data",
      "label": "Group Code",
      "reqd": 1,
      "unique": 1,
      "in_list_view": 1,
      "description": "Unique identifier (slug). Example: general, dimensions, seo"
    },
    {
      "fieldname": "column_break_1",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "sort_order",
      "fieldtype": "Int",
      "label": "Sort Order",
      "default": 0,
      "in_list_view": 1,
      "description": "Order in which groups appear (lower = first)"
    },
    {
      "fieldname": "is_standard",
      "fieldtype": "Check",
      "label": "Is Standard",
      "default": 0,
      "read_only": 1,
      "description": "System attribute group, cannot be deleted"
    },
    {
      "fieldname": "parent_group",
      "fieldtype": "Link",
      "label": "Parent Group",
      "options": "PIM Attribute Group",
      "in_standard_filter": 1,
      "description": "Parent group for hierarchical grouping of attributes"
    },
    {
      "fieldname": "section_break_display",
      "fieldtype": "Section Break",
      "label": "Display Settings"
    },
    {
      "fieldname": "icon",
      "fieldtype": "Data",
      "label": "Icon",
      "description": "FontAwesome icon name (e.g., fa-cog, fa-ruler, fa-search)"
    },
    {
      "fieldname": "color",
      "fieldtype": "Color",
      "label": "Color",
      "description": "Color for visual identification in UI"
    },
    {
      "fieldname": "column_break_display",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "is_collapsible",
      "fieldtype": "Check",
      "label": "Collapsible",
      "default": 0,
      "description": "Allow group to be collapsed in product form"
    },
    {
      "fieldname": "is_collapsed_default",
      "fieldtype": "Check",
      "label": "Collapsed by Default",
      "default": 0,
      "depends_on": "eval:doc.is_collapsible",
      "description": "Start collapsed when viewing product"
    },
    {
      "fieldname": "section_break_description",
      "fieldtype": "Section Break",
      "label": "Description"
    },
    {
      "fieldname": "description",
      "fieldtype": "Small Text",
      "label": "Description",
      "description": "Brief description of what attributes belong in this group"
    }
  ],

  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "export": 1,
      "import": 1
    },
    {
      "role": "PIM Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "export": 1,
      "import": 1
    },
    {
      "role": "PIM User",
      "read": 1
    }
  ]
}
