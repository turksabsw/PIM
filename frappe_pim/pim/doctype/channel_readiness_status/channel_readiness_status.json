{
  "doctype": "DocType",
  "name": "Channel Readiness Status",
  "module": "PIM",
  "istable": 1,
  "editable_grid": 1,
  "track_changes": 0,
  "engine": "InnoDB",

  "fields": [
    {
      "fieldname": "channel",
      "fieldtype": "Link",
      "label": "Channel",
      "options": "Channel",
      "reqd": 1,
      "in_list_view": 1,
      "in_standard_filter": 1,
      "columns": 2
    },
    {
      "fieldname": "completeness_score",
      "fieldtype": "Percent",
      "label": "Completeness Score",
      "default": 0,
      "in_list_view": 1,
      "columns": 1,
      "description": "Channel-specific completeness percentage (0-100)"
    },
    {
      "fieldname": "is_ready",
      "fieldtype": "Check",
      "label": "Ready",
      "default": 0,
      "in_list_view": 1,
      "columns": 1,
      "description": "Product is ready for publishing to this channel"
    },
    {
      "fieldname": "critical_gaps",
      "fieldtype": "Int",
      "label": "Critical Gaps",
      "default": 0,
      "in_list_view": 1,
      "columns": 1,
      "description": "Number of critical missing fields blocking publishing"
    },
    {
      "fieldname": "required_gaps",
      "fieldtype": "Int",
      "label": "Required Gaps",
      "default": 0,
      "in_list_view": 1,
      "columns": 1,
      "description": "Number of required missing fields"
    },
    {
      "fieldname": "column_break_1",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "recommended_gaps",
      "fieldtype": "Int",
      "label": "Recommended Gaps",
      "default": 0,
      "description": "Number of recommended missing fields"
    },
    {
      "fieldname": "last_calculated",
      "fieldtype": "Datetime",
      "label": "Last Calculated",
      "read_only": 1,
      "in_list_view": 1,
      "columns": 2,
      "description": "When completeness was last calculated"
    },
    {
      "fieldname": "section_missing_details",
      "fieldtype": "Section Break",
      "label": "Missing Details",
      "collapsible": 1
    },
    {
      "fieldname": "missing_attributes",
      "fieldtype": "JSON",
      "label": "Missing Attributes",
      "description": "JSON list of missing attribute names and their importance levels"
    },
    {
      "fieldname": "column_break_2",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "validation_errors",
      "fieldtype": "JSON",
      "label": "Validation Errors",
      "description": "JSON list of validation errors for this channel"
    },
    {
      "fieldname": "section_media",
      "fieldtype": "Section Break",
      "label": "Media Status",
      "collapsible": 1
    },
    {
      "fieldname": "media_complete",
      "fieldtype": "Check",
      "label": "Media Complete",
      "default": 0,
      "description": "All required media/images for this channel are present"
    },
    {
      "fieldname": "media_gaps",
      "fieldtype": "JSON",
      "label": "Media Gaps",
      "description": "JSON list of missing or non-compliant media items"
    },
    {
      "fieldname": "column_break_3",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "image_count",
      "fieldtype": "Int",
      "label": "Image Count",
      "default": 0,
      "description": "Number of images associated with product for this channel"
    },
    {
      "fieldname": "min_images_required",
      "fieldtype": "Int",
      "label": "Min Images Required",
      "default": 1,
      "read_only": 1,
      "description": "Minimum images required by this channel"
    },
    {
      "fieldname": "section_scores",
      "fieldtype": "Section Break",
      "label": "Score Breakdown",
      "collapsible": 1
    },
    {
      "fieldname": "critical_score",
      "fieldtype": "Percent",
      "label": "Critical Score",
      "default": 0,
      "description": "Score for critical fields (40% weight)"
    },
    {
      "fieldname": "required_score",
      "fieldtype": "Percent",
      "label": "Required Score",
      "default": 0,
      "description": "Score for required fields (40% weight)"
    },
    {
      "fieldname": "column_break_4",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "recommended_score",
      "fieldtype": "Percent",
      "label": "Recommended Score",
      "default": 0,
      "description": "Score for recommended fields (20% weight)"
    },
    {
      "fieldname": "remediation_summary",
      "fieldtype": "Small Text",
      "label": "Remediation Summary",
      "read_only": 1,
      "description": "Brief summary of steps needed to make product channel-ready"
    }
  ],

  "permissions": []
}
